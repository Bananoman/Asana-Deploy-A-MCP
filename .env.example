# Asana MCP Server - Environment Configuration

# Required: Your Asana Personal Access Token
# Get it from: https://app.asana.com/0/my-apps
ASANA_TOKEN=ASANA_TOKEN_REDACTED_ROTATED

# Optional: Logging configuration
LOG_LEVEL=info              # Options: debug, info, warn, error
MCP_LOG_DIR=/tmp/deploy-a-mcp-logs

# Optional: Cache configuration
CACHE_TTL=300              # Cache TTL in seconds (default: 300)
CACHE_MAX_SIZE=1000        # Maximum number of cached items

# Optional: Rate limiting
RATE_LIMIT_MAX_REQUESTS=1400   # Max requests per minute
RATE_LIMIT_CONCURRENT=150      # Max concurrent requests

# Optional: Tool loading mode (saves ~80K tokens in efficient mode)
ASANA_TOOL_MODE=efficient      # full | efficient (default) | minimal

# Optional: Domain filtering (load only tools you need)
ASANA_DOMAINS=all              # all (default) | comma-separated: workspace,projects,tasks,portfolio,goals,automation,reporting,collaboration,advanced,advisor

# Optional: Response mode (reduces response tokens by 50-70%)
ASANA_RESPONSE_MODE=full       # full (default) | compact
